@startuml MCP Server - Use Case View
title MCP Server 用例视图 (Use Case View)

skinparam backgroundColor #FEFEFE

skinparam usecase {
    BackgroundColor #E3F2FD
    BorderColor #1976D2
}

skinparam actor {
    BackgroundColor #E8F5E9
    BorderColor #4CAF50
}

' =============================================
' 角色定义
' =============================================

actor "LLM Client\n(Claude Desktop, Web App)" as LLMClient
actor "Developer" as Developer
actor "System Administrator" as Admin

' =============================================
' 核心用例
' =============================================

rectangle "服务器管理" {
    usecase "启动服务器" as UC_Startup
    usecase "配置服务器" as UC_Config
    usecase "停止服务器" as UC_Shutdown
    usecase "查看服务器信息" as UC_Info
}

rectangle "工具管理" {
    usecase "注册工具" as UC_RegTool
    usecase "列出可用工具" as UC_ListTools
    usecase "调用工具" as UC_CallTool
}

rectangle "资源管理" {
    usecase "注册资源" as UC_RegResource
    usecase "列出资源" as UC_ListResources
    usecase "读取资源" as UC_ReadResource
}

rectangle "提示模板管理" {
    usecase "注册提示模板" as UC_RegPrompt
    usecase "列出提示模板" as UC_ListPrompts
    usecase "获取提示模板" as UC_GetPrompt
}

rectangle "日志管理" {
    usecase "配置日志" as UC_LogConfig
    usecase "查看日志" as UC_LogView
}

' =============================================
' 角色与用例关联
' =============================================

Admin --> UC_Startup
Admin --> UC_Config
Admin --> UC_Shutdown
Admin --> UC_Info

Developer --> UC_RegTool
Developer --> UC_RegResource
Developer --> UC_RegPrompt
Developer --> UC_LogConfig

LLMClient --> UC_ListTools
LLMClient --> UC_CallTool
LLMClient --> UC_ListResources
LLMClient --> UC_ReadResource
LLMClient --> UC_ListPrompts
LLMClient --> UC_GetPrompt

Admin --> UC_LogView

' =============================================
' 用例包含关系
' =============================================

UC_CallTool ..> UC_ListTools : <<include>>
UC_ReadResource ..> UC_ListResources : <<include>>
UC_GetPrompt ..> UC_ListPrompts : <<include>>

UC_Startup ..> UC_Config : <<include>>
UC_Startup ..> UC_LogConfig : <<include>>

' =============================================
' 扩展关系
' =============================================
'
'UC_CallTool ..> "处理工具错误" as UC_Error : <<extend>>
'UC_ReadResource ..> UC_Error : <<extend>>
'UC_GetPrompt ..> UC_Error : <<extend>>

' =============================================
' 用例详细说明
' =============================================

note right of UC_Startup
    <b>启动服务器</b>

    <i>前置条件:</i>
    • config.json 存在且有效

    <i>主流程:</i>
    1. 加载配置文件
    2. 初始化日志系统
    3. 创建 McpServerRunner
    4. 注册 MCP 方法
    5. 启动传输层

    <i>后置条件:</i>
    服务器就绪,接受请求
end note

note right of UC_CallTool
    <b>调用工具</b>

    <i>前置条件:</i>
    • 服务器已启动
    • 工具已注册

    <i>主流程:</i>
    1. 客户端发送 tools/call
    2. 验证工具名称存在
    3. 验证参数符合 Schema
    4. 执行 ToolHandler
    5. 返回 ToolResult

    <i>异常:</i>
    • 工具不存在 → 错误响应
    • 参数无效 → 错误响应
    • 执行失败 → is_error=true
end note

note right of UC_ReadResource
    <b>读取资源</b>

    <i>前置条件:</i>
    • 服务器已启动
    • 资源已注册

    <i>主流程:</i>
    1. 客户端发送 resources/read
    2. 验证 URI 存在
    3. 执行 ResourceReadHandler
    4. 返回 ResourceContent

    <i>支持类型:</i>
    • text/plain
    • application/json
    • 自定义 MIME 类型
end note

note right of UC_GetPrompt
    <b>获取提示模板</b>

    <i>前置条件:</i>
    • 服务器已启动
    • 提示模板已注册

    <i>主流程:</i>
    1. 客户端发送 prompts/get
    2. 验证模板名称存在
    3. 验证必填参数
    4. 执行 PromptGetHandler
    5. 返回 PromptResult (messages[])
end note

note right of UC_RegTool
    <b>注册工具</b>

    <i>调用者:</i> Developer (代码中)

    <i>参数:</i>
    • name: 工具名称
    • description: 工具描述
    • inputSchema: JSON Schema
    • handler: ToolHandler 函数

    <i>示例:</i>
    registerTool({
        .name = "echo",
        .description = "回显输入",
        .inputSchema = {...},
        .handler = echoHandler
    });
end note

'note bottom of diagram
'    <b>MCP 方法映射:</b>
'
'    | 用例 | MCP 方法 |
'    | 启动服务器 | initialize |
'    | 列出工具 | tools/list |
'    | 调用工具 | tools/call |
'    | 列出资源 | resources/list |
'    | 读取资源 | resources/read |
'    | 列出提示模板 | prompts/list |
'    | 获取提示模板 | prompts/get |
'end note

' =============================================
' 用例优先级
' =============================================

'



legend right
    |<back:back: #E8F5E9> 绿色 | LLM 客户端 |
    |<back:back: #FFF3E0> 橙色 | 开发者 |
    |<back:back: #FFF9C4> 黄色 | 系统管理员 |
    |<back:back: #F3E5F5> 紫色 | 服务器管理 |
    |<back:back: #E1F5FE> 蓝色 | 工具管理 |
    |<back:back: #E0F2F1> 青色 | 资源管理 |
    |<back:back: #F1F8E9> 浅绿 | 提示模板管理 |
    |<back:back: #FFEBEE> 红色 | 日志管理 |
endlegend

@enduml
