@startuml JSON-RPC 模块时序图
!theme plain
skinparam backgroundColor #FEFEFE
skinparam handwritten false
skinparam sequenceMessageAlign center
skinparam noteBackgroundColor #FEFECE
skinparam noteBorderColor #E0E000

title JSON-RPC 2.0 模块 - 方法注册与调用流程

actor Client as client
participant "StdioJsonRpc\n(传输层)" as transport
participant "JsonRpc\n(协议层)" as protocol
participant "JsonRpcSerialization\n(序列化层)" as serialization
participant "MethodRegistry\n(方法注册表)" as registry
participant "UserHandler\n(业务逻辑)" as handler

== 初始化阶段 ==

client -> protocol : 1. 创建 JsonRpc 实例
activate protocol

protocol -> registry : 2. 初始化方法注册表
activate registry
registry --> protocol : 注册表就绪
deactivate registry

client -> transport : 3. 创建 StdioJsonRpc(rpc)
activate transport
transport --> protocol : 持有 JsonRpc 引用

== 方法注册阶段 ==

handler -> protocol : 4. registerMethod("add", handler)
activate protocol

protocol -> protocol : 5. 验证方法名和处理器

protocol -> registry : 6. 存储方法映射
activate registry
note right of registry
  methods_["add"] = {
    syncHandler: handler,
    asyncHandler: nullptr,
    isAsync: false
  }
end note

registry --> protocol : 注册成功
deactivate registry

protocol --> handler : 返回 true
deactivate protocol

== 请求接收阶段 ==

client -> transport : 8. stdin: {"jsonrpc":"2.0","method":"add","params":[3,5],"id":1}
activate transport

transport -> transport : 9. readLine() 读取一行

transport -> serialization : 10. 反序列化 JSON 字符串
activate serialization

serialization -> serialization : 11. 验证 JSON-RPC 2.0 格式\n- jsonrpc == "2.0"\n- method 存在\n- params 格式正确

serialization --> transport : 返回 Request 对象
deactivate serialization

transport -> protocol : 12. handleRequest(request)
activate protocol

== 请求处理阶段 ==

protocol -> protocol : 13. validateRequest(request)\n(严格模式)

protocol -> registry : 14. 查找 "add" 方法
activate registry
registry --> protocol : 返回 MethodEntry
deactivate registry

alt 方法存在
    protocol -> handler : 15. 调用 handler("add", [3, 5])
    activate handler

    handler -> handler : 16. 执行业务逻辑\nreturn 3 + 5

    handler --> protocol : 返回结果 8
    deactivate handler

    protocol -> serialization : 17. createSuccessResponse(8, id=1)
    activate serialization
    serialization --> protocol : 返回 Response 对象
    deactivate serialization

    protocol -> serialization : 18. serializeResponse(response)
    activate serialization
    serialization --> protocol : 返回 JSON 字符串
    deactivate serialization

    protocol --> transport : 返回响应字符串
    deactivate protocol

    transport -> client : 19. stdout: {"jsonrpc":"2.0","result":8,"id":1}
    deactivate transport

else 方法不存在
    protocol -> serialization : createErrorResponse(METHOD_NOT_FOUND)
    serialization --> protocol : 返回错误响应
    protocol --> transport : 返回错误 JSON
    transport -> client : stdout: {"jsonrpc":"2.0","error":{"code":-32601,...}}
end

== 通知处理 (无 ID) ==

client -> transport : stdin: {"jsonrpc":"2.0","method":"notify","params":[...]}
activate transport

transport -> protocol : handleRequest(request)
activate protocol

protocol -> protocol : 检测到 request.isNotification()

protocol -> handler : 调用处理器 (不等待响应)

protocol --> transport : 返回 std::nullopt
deactivate protocol

note right of transport
  通知不发送响应
  直接处理下一条消息
end note

deactivate transport

== 异常处理 ==

client -> transport : stdin: {"jsonrpc":"2.0","method":"divide","params":[10,0],"id":2}
activate transport

transport -> protocol : handleRequest(request)
activate protocol

protocol -> handler : 调用处理器
activate handler

handler -> handler : 抛出异常\nthrow std::runtime_error("Division by zero")

handler --> protocol : 异常传播
deactivate handler

protocol -> protocol : 捕获异常\n触发 exceptionHandler_

protocol -> serialization : createErrorResponse(INTERNAL_ERROR, exception msg)
serialization --> protocol : 返回错误响应

protocol --> transport : 返回错误 JSON
deactivate protocol

transport -> client : stdout: {"jsonrpc":"2.0","error":{"code":-32603,"message":"Internal error",...}}
deactivate transport

== 批量请求处理 ==

client -> transport : stdin: [{"jsonrpc":"2.0",...},{...},...]
activate transport

transport -> serialization : deserializeBatchRequest(json)
activate serialization

serialization -> serialization : 解析 JSON 数组

serialization --> transport : 返回 BatchRequest
deactivate serialization

transport -> protocol : handleBatchRequest(batch)
activate protocol

loop 每个请求
    protocol -> protocol : 处理单个请求
    protocol -> serialization : 创建响应
end

protocol -> serialization : serializeBatchResponse(responses)
activate serialization
serialization --> protocol : 返回 JSON 数组字符串
deactivate serialization

protocol --> transport : 返回批量响应
deactivate protocol

transport -> client : stdout: [{...},{...},...]
deactivate transport

@enduml
