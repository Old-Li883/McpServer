@startuml MCP Agent ReAct流程图 (RAG增强版)
title MCP Agent ReAct (Reasoning + Acting + RAG) 模式详细流程

skinparam backgroundColor #FEFEFE
skinparam handwritten false
skinparam shadowing false
skinparam noteFontSize 10
skinparam noteBackgroundColor #FEFECE

start

:接收用户消息;
note right
  **agent_engine.py:66-89**
  process_message() 方法
end note

partition "RAG 增强 (可选)" #Lavender {
  :检查RAG是否启用;
  note right
    **_should_use_rag()**
    检测问题关键词
  end note

  if (RAG启用且需要检索?) then (是)
    :调用RAG引擎检索相关知识;
    note right
      **_rag_enhance_query()**
      1. 查询向量数据库
      2. 获取最相关文档
      3. 构建上下文
    end note

    :构建增强的用户消息;
    note right
      原始消息 + RAG上下文
    end note
  else (否)
    :使用原始用户消息;
  endif
}

:添加消息到对话历史;
note right
  可能包含RAG上下文
end note

:初始化 ReAct 循环;
note right
  **_process_with_tools()**
  iteration = 0
  used_tools = {}
  final_response = ""
end note

while (iteration < max_iterations?) is (是)
  note right
    **agent_engine.py:109**
    最大迭代次数: 默认5次
  end note

  :iteration++;

  partition "Observe (观察)" #LightBlue {
    :从对话历史获取消息列表;
    note right
      **agent_engine.py:113**
      conversation.get_messages_for_llm()
      包含: 系统提示、RAG上下文(如有)、
      用户消息、助手响应、工具结果
    end note
  }

  partition "Think (思考)" #LightGreen {
    :调用LLM生成响应;
    note right
      **agent_engine.py:116**
      _generate_response(messages)
      使用 OllamaClient.chat()
      温度: 0.7
      最大tokens: 2048
    end note

    :解析LLM响应中的工具调用;
    note right
      **agent_engine.py:119-120**
      parse_tool_calls()
      检测工具调用语法
      提取工具名和参数
    end note
  }

  partition "工具推断 (可选)" #LightYellow {
    if (第一次迭代且无工具调用?) then (是)
      :从用户消息推断工具调用;
      note right
        **agent_engine.py:124-130**
        _infer_tool_calls()
        使用正则表达式匹配
      end note

      if (推断出工具调用?) then (是)
        :过滤已使用的工具;
        :添加到工具调用列表;
      endif
    endif
  }

  partition "Act (行动)" #LightCoral {
    :添加助手响应到对话历史;
    note right
      **agent_engine.py:133-136**
    end note

    if (检测到工具调用?) then (是)
      note right
        **agent_engine.py:158-182**
        遍历工具调用列表
      end note

      :获取下一个工具调用;

      while (还有工具调用?) is (是)
        if (工具已使用?) then (是)
          :跳过此工具;
        else (否)
          :标记工具为已使用;

          :执行工具;
          note right
            **tool_orchestrator.execute_tool()**
            通过MCP Client调用
            远程工具服务
          end note

          if (执行成功?) then (是)
            :格式化工具结果;
            :添加工具消息到对话;
            note right
              **agent_engine.py:171-175**
              format_tool_result()
              添加 [Tool: name] 前缀
            end note
          else (否)
            :添加错误消息到对话;
          endif
        endif

        :获取下一个工具调用;
      endwhile (否)

      :继续下一次迭代;

    else (否 - 无工具调用)
      if (响应为空且有工具结果?) then (是)
        :使用最后的工具结果作为响应;
        note right
          **agent_engine.py:141-150**
        end note
      else (否)
        :使用LLM生成的文本作为响应;
        note right
          **agent_engine.py:154**
        end note
      endif

      :设置完成标志并退出循环;
    endif
  }

endwhile (否)

:返回最终响应;
note right
  **agent_engine.py:187**
  返回给CLI界面
end note

stop

@enduml
